<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canchas Disponibles - Golazo App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-dark text-light" 
      style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark bg-opacity-75 border-bottom border-secondary sticky-top mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/cliente/listado">
            <i class="fas fa-futbol text-primary"></i> GOLAZO APP
        </a>

        <div class="d-flex align-items-center gap-3">
            <a href="/cliente/mis-reservas" class="nav-link text-info fw-bold">
                <i class="fas fa-history"></i> Mis Reservas
            </a>

            <a href="/logout" class="btn btn-outline-danger btn-sm">
                <i class="fas fa-sign-out-alt"></i> Salir
            </a>
        </div>
    </div>
</nav>

<div class="container pb-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Reserva tu Cancha</h1>
        <p class="text-secondary">Selecciona el campo de juego y revisa los horarios disponibles.</p>
    </div>

    <div class="row g-4">
        <% if (typeof canchas !== 'undefined' && canchas.length > 0) { %>

            <% canchas.forEach(cancha => { %>

                <div class="col-md-4 col-sm-6">
                    <div class="card bg-dark text-light border-secondary h-100 shadow">

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="fw-bold mb-0"><%= cancha.nombre %></h5>

                                <span class="badge bg-secondary">
                                    <i class="fas fa-medal me-1"></i>
                                    <%= cancha.detalleTipo ? cancha.detalleTipo.descripcion : 'Deporte' %>
                                </span>
                            </div>

                            <div class="mb-3">
                                <% 
                                    const promedio = cancha.getDataValue('promedioEstrellas');
                                    const total = cancha.getDataValue('totalResenas');
                                %>

                                <% if (total > 0 && promedio) { %>
                                    <div>
                                        <span class="text-warning">
                                            <% for(let i=0; i < Math.round(promedio); i++) { %>
                                                <i class="fas fa-star"></i>
                                            <% } %>
                                        </span>
                                        <span class="ms-1 fw-bold"><%= parseFloat(promedio).toFixed(1) %></span>
                                        <small class="text-secondary">(<%= total %> reseñas)</small>
                                    </div>
                                <% } else { %>
                                    <small class="text-secondary">
                                        <i class="far fa-star"></i> Sin valoraciones
                                    </small>
                                <% } %>
                            </div>

                            <div class="mt-auto border-top border-secondary pt-3 mb-3">
                                <small class="text-secondary d-block">Precio</small>
                                <span class="fw-bold text-success fs-5">
                                    Bs. <%= cancha.precioHora %>
                                </span>
                                <small class="text-secondary">/ hora</small>
                            </div>

                            <a href="/cliente/cancha/<%= cancha.id %>" class="btn btn-primary w-100 fw-bold">
                                <i class="fas fa-calendar-check me-2"></i> Ver Disponibilidad
                            </a>

                        </div>
                    </div>
                </div>

            <% }) %>

        <% } else { %>

            <div class="col-12 text-center py-5">
                <div class="alert alert-dark border-secondary">
                    <i class="fas fa-search fa-2x mb-3 text-secondary"></i>
                    <h4>No hay campos disponibles</h4>
                    <p class="mb-0">En este momento no hay canchas activas.</p>
                </div>
            </div>

        <% } %>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>