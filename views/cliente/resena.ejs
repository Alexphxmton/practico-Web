<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dejar Reseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white p-5">
    <div class="container" style="max-width: 500px;">
        <div class="card bg-secondary text-white p-4 shadow">
            <h3>Reseñar: <%= reserva.detalleHorario.datosCancha.nombre %></h3>
            <hr>
            <form action="/cliente/resena/guardar" method="POST">
                <input type="hidden" name="canchaId" value="<%= reserva.detalleHorario.datosCancha.id %>">
                
                <div class="mb-3">
                    <label class="form-label">Calificación (1 a 5):</label>
                    <select name="calificacion" class="form-select" required>
                        <option value="5">⭐⭐⭐⭐⭐ (Excelente)</option>
                        <option value="4">⭐⭐⭐⭐ (Bueno)</option>
                        <option value="3">⭐⭐⭐ (Regular)</option>
                        <option value="2">⭐⭐ (Malo)</option>
                        <option value="1">⭐ (Pésimo)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Comentario:</label>
                    <textarea name="comentario" class="form-control" rows="3" placeholder="¿Qué tal estuvo la cancha?"></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100">Publicar Reseña</button>
                <a href="/cliente/mis-reservas" class="btn btn-link text-white w-100 mt-2">Cancelar</a>
            </form>
        </div>
    </div>
</body>
</html>