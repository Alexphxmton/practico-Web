<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Reservas - Gestión de Canchas</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f8f9fa; padding: 20px; color: #333; }
        .container { max-width: 900px; margin: auto; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        
        .reserva-card { 
            background: white; 
            border-radius: 10px; 
            padding: 20px; 
            margin-bottom: 15px; 
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 5px solid #3498db;
        }

        .info h3 { margin: 0 0 10px 0; color: #2c3e50; }
        .info p { margin: 5px 0; font-size: 0.95rem; }
        
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: bold;
            text-transform: uppercase;
        }
        .status-confirmada { background: #d4edda; color: #155724; }
        .status-cancelada { background: #f8d7da; color: #721c24; }

        .btn-cancelar {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-cancelar:hover { background-color: #c0392b; }
        
        .btn-volver { text-decoration: none; color: #3498db; font-weight: bold; }
        .no-reservas { text-align: center; padding: 50px; background: white; border-radius: 10px; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Mis Reservas</h1>
        <a href="/cliente/listado" class="btn-volver">← Volver a canchas</a>
    </div>

    <% if (reservas && reservas.length > 0) { %>
        <% reservas.forEach(reserva => { %>
            <div class="reserva-card" style="<%= reserva.estado === 'cancelada' ? 'border-left-color: #bdc3c7; opacity: 0.8;' : '' %>">
                <div class="info">
                    <h3><%= reserva.detalleHorario.datosCancha.nombre %></h3>
                    <p><strong>Fecha:</strong> <%= reserva.detalleHorario.fecha %></p>
                    <p><strong>Horario:</strong> <%= reserva.detalleHorario.horaInicio %> - <%= reserva.detalleHorario.horaFin %></p>
                    <p><strong>Pago:</strong> $<%= reserva.totalPago %></p>
                    <p>
                        <span class="status-badge status-<%= reserva.estado %>">
                            <%= reserva.estado %>
                        </span>
                    </p>
                </div>

                <div class="acciones">
                    <% if (reserva.estado === 'confirmada') { %>
                        <form action="/cliente/cancelar/<%= reserva.id %>" method="POST" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta reserva?')">
                            <button type="submit" class="btn-cancelar">Cancelar</button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="no-reservas">
            <p>Todavía no has realizado ninguna reserva.</p>
            <br>
            <a href="/cliente/listado" style="background: #3498db; color: white; padding: 10px 20px; border-radius: 5px; text-decoration: none;">Ver Canchas Disponibles</a>
        </div>
    <% } %>
</div>

</body>
</html>