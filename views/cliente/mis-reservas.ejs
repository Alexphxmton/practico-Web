<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Reservas - Gestión de Canchas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-dark text-light"
      style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold mb-0">
            <i class="fas fa-calendar-check text-primary"></i> Mis Reservas
        </h2>

        <a href="/cliente/listado" class="btn btn-outline-info btn-sm">
            <i class="fas fa-arrow-left"></i> Volver
        </a>
    </div>

    <% if (reservas && reservas.length > 0) { %>

        <% reservas.forEach(reserva => { %>

            <div class="card bg-dark text-light border-secondary mb-3 shadow <%= reserva.estado === 'cancelada' ? 'opacity-50' : '' %>">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <div>
                        <h5 class="fw-bold text-info mb-2">
                            <%= reserva.detalleHorario.datosCancha.nombre %>
                        </h5>

                        <p class="mb-1 small text-secondary">
                            <i class="far fa-calendar-alt"></i>
                            <strong>Fecha:</strong> <%= reserva.detalleHorario.fecha %>
                        </p>

                        <p class="mb-1 small text-secondary">
                            <i class="far fa-clock"></i>
                            <strong>Horario:</strong>
                            <%= reserva.detalleHorario.horaInicio.slice(0,5) %> -
                            <%= reserva.detalleHorario.horaFin.slice(0,5) %>
                        </p>

                        <p class="mb-2 small">
                            <i class="fas fa-money-bill-wave"></i>
                            <strong>Pago:</strong>
                            <span class="text-success fw-bold">Bs. <%= reserva.totalPago %></span>
                        </p>

                        <span class="badge 
                            <%= reserva.estado === 'confirmada' ? 'bg-success' : '' %>
                            <%= reserva.estado === 'pagada' ? 'bg-primary' : '' %>
                            <%= reserva.estado === 'cancelada' ? 'bg-secondary' : '' %>">
                            <%= reserva.estado.toUpperCase() %>
                        </span>
                    </div>

                    <div class="text-end">

                        <% if (reserva.estado === 'confirmada' || reserva.estado === 'pagada') { %>

                            <a href="/cliente/resena/<%= reserva.id %>" class="btn btn-warning btn-sm fw-bold mb-2">
                                <i class="fas fa-star"></i> Reseña
                            </a>

                            <% if (reserva.estado === 'confirmada') { %>
                                <form action="/cliente/cancelar/<%= reserva.id %>" method="POST"
                                      onsubmit="return confirm('¿Seguro que deseas cancelar la reserva?')">
                                    <button type="submit" class="btn btn-danger btn-sm w-100">
                                        Cancelar
                                    </button>
                                </form>
                            <% } %>

                        <% } %>

                    </div>

                </div>
            </div>

        <% }) %>

    <% } else { %>

        <div class="text-center py-5">
            <div class="alert alert-dark border-secondary">
                <i class="fas fa-folder-open fa-3x text-secondary mb-3"></i>
                <h5>No tienes reservas</h5>
                <p class="text-secondary">Aún no has reservado ninguna cancha.</p>

                <a href="/cliente/listado" class="btn btn-primary">
                    Explorar Canchas
                </a>
            </div>
        </div>

    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>