<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Reservar - <%= cancha.nombre %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark" style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">

    <div class="bg-dark bg-opacity-50 p-5 rounded-3 shadow border border-secondary text-center text-white mb-5">
        <h1 class="fw-bold"><%= cancha.nombre %></h1>
        <p class="mt-2">
            Precio por hora: 
            <span class="text-success fw-bold fs-4">Bs <%= cancha.precioHora %></span>
        </p>
    </div>

    <div class="mb-4">
        <h3 class="text-info border-bottom border-secondary pb-2">Horarios Disponibles</h3>
    </div>

    <div class="row g-4">

        <% if (cancha.listaHorarios && cancha.listaHorarios.length > 0) { %>

            <% cancha.listaHorarios.forEach(horario => { %>

                <div class="col-md-4">
                    <div class="card bg-dark bg-opacity-75 text-white shadow border border-secondary h-100">

                        <div class="card-body text-center">

                            <p class="fw-semibold mb-2">Horario</p>

                            <h5 class="mb-3">
                                <%= horario.horaInicio.slice(0,5) %> - 
                                <%= horario.horaFin.slice(0,5) %>
                            </h5>

                            <% if (horario.disponible) { %>

                                <form action="/cliente/reservar" method="POST">
                                    <input type="hidden" name="horarioId" value="<%= horario.id %>">
                                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                                        Reservar
                                    </button>
                                </form>

                            <% } else { %>

                                <button class="btn btn-secondary w-100" disabled>
                                    No Disponible
                                </button>

                            <% } %>

                        </div>

                    </div>
                </div>

            <% }) %>

        <% } else { %>

            <div class="col-12">
                <div class="alert alert-dark text-white text-center border-secondary py-5">
                    No hay horarios disponibles
                </div>
            </div>

        <% } %>

    </div>

    <div class="mt-5">
        <h3 class="text-info border-bottom border-secondary pb-2 mb-4">Opiniones</h3>

        <div class="row g-4">

            <% if (cancha.todasLasResenas && cancha.todasLasResenas.length > 0) { %>

                <% cancha.todasLasResenas.forEach(resena => { %>

                    <div class="col-md-6">
                        <div class="card bg-dark bg-opacity-75 text-white shadow border border-secondary h-100">

                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-bold text-info">
                                        <%= resena.propietario ? resena.propietario.nombre : 'Usuario' %>
                                    </span>

                                    <span class="text-warning">
                                        <% for(let i = 0; i < resena.calificacion; i++) { %>★<% } %>
                                    </span>
                                </div>

                                <p class="mb-0">
                                    "<%= resena.comentario %>"
                                </p>

                            </div>

                        </div>
                    </div>

                <% }) %>

            <% } else { %>

                <div class="col-12">
                    <div class="alert alert-dark text-white text-center border-secondary">
                        Aún no hay reseñas
                    </div>
                </div>

            <% } %>

        </div>
    </div>

    <div class="mt-5 text-center">
        <a href="/cliente/listado" class="btn btn-outline-light">
            ← Volver
        </a>
    </div>

</div>

</body>
</html>