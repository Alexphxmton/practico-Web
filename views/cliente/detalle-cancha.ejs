<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservar - <%= cancha.nombre %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 20px; background-color: #0b0f19; color: #e9ecef; }
        .container { max-width: 1000px; margin: auto; }
        
        .cancha-header { 
            background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%); 
            color: white; padding: 40px; border-radius: 15px; 
            margin-bottom: 30px; box-shadow: 0 10px 15px rgba(0,0,0,0.3);
            border: 1px solid #4a5568;
        }
        .cancha-header h1 { margin: 0; font-size: 2.8rem; }
        .precio { font-size: 1.8rem; font-weight: bold; color: #48bb78; }
        
        h2 { border-bottom: 2px solid #3182ce; padding-bottom: 10px; color: #63b3ed; margin-top: 40px; }
        
        .horarios-container { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
            gap: 20px; margin-top: 20px;
        }
        
        .horario-card { 
            background: #1a202c; padding: 20px; border: 1px solid #2d3748; 
            border-radius: 12px; text-align: center; transition: 0.3s;
        }
        .horario-card:hover { border-color: #3182ce; transform: translateY(-3px); }
        
        .btn-reservar { 
            background: #3182ce; color: white; border: none; 
            padding: 12px 20px; border-radius: 8px; cursor: pointer; 
            font-weight: bold; width: 100%; font-size: 1rem; transition: 0.3s;
        }
        .btn-reservar:hover { background: #2b6cb0; }
        .btn-reservar:disabled { background: #4a5568; cursor: not-allowed; opacity: 0.6; }

        /* SECCIÓN DE RESEÑAS */
        .resenas-section { margin-top: 50px; background: #1a202c; padding: 30px; border-radius: 15px; border: 1px solid #2d3748; }
        .resena-item { border-bottom: 1px solid #2d3748; padding: 15px 0; }
        .resena-item:last-child { border-bottom: none; }
        .estrellas { color: #ecc94b; margin-bottom: 5px; }
        .usuario-nombre { font-weight: bold; color: #63b3ed; font-size: 0.9rem; }
        .comentario { font-style: italic; color: #a0aec0; margin-top: 5px; }

        .back-link { display: inline-block; margin-top: 30px; color: #63b3ed; text-decoration: none; font-weight: bold; }
        .back-link:hover { text-underline-offset: 5px; text-decoration: underline; }
    </style>
</head>
<body>

<div class="container">
    <div class="cancha-header text-center">
        <h1><%= cancha.nombre %></h1>
        <p>Precio por hora: <span class="precio">Bs. <%= cancha.precioHora %></span></p>
    </div>

    <h2><i class="fas fa-clock"></i> Horarios Disponibles</h2>
    <div class="horarios-container">
        <% if (cancha.listaHorarios && cancha.listaHorarios.length > 0) { %>
            <% cancha.listaHorarios.forEach(horario => { %>
                <div class="horario-card">
                    <p><strong>Bloque:</strong></p>
                    <p><%= horario.horaInicio.slice(0,5) %> - <%= horario.horaFin.slice(0,5) %></p>
                    
                    <% if (horario.disponible) { %>
                        <form action="/cliente/reservar" method="POST">
                            <input type="hidden" name="horarioId" value="<%= horario.id %>">
                            <button type="submit" class="btn-reservar">Reservar Ahora</button>
                        </form>
                    <% } else { %>
                        <button class="btn-reservar" disabled>No Disponible</button>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1/-1; text-align: center; padding: 40px; background: #2d3748; border-radius: 10px;">
                <p>⚠️ No hay horarios disponibles para hoy.</p>
            </div>
        <% } %>
    </div>

<div class="resenas-section">
    <h2><i class="fas fa-star"></i> Opiniones de la Comunidad</h2>
    
    <% if (cancha.todasLasResenas && cancha.todasLasResenas.length > 0) { %>
        <% cancha.todasLasResenas.forEach(resena => { %>
            <div class="resena-item">
                <div class="usuario-nombre">
                    <i class="fas fa-user-circle"></i> 
                    <%= resena.propietario ? resena.propietario.nombre : 'Usuario de Golazo' %>
                </div>
                <div class="estrellas">
                    <% for(let i=0; i < resena.calificacion; i++) { %>
                        <i class="fas fa-star"></i>
                    <% } %>
                </div>
                <p class="comentario">"<%= resena.comentario %>"</p>
            </div>
        <% }) %>
    <% } else { %>
        <p class="text-muted text-center">Aún no hay opiniones para esta cancha.</p>
    <% } %>
</div>

    <a href="/cliente/listado" class="back-link">← Volver al listado de canchas</a>
</div>

</body>
</html>