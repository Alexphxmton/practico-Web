<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Reservas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark" style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-5 bg-dark bg-opacity-50 p-4 rounded-3 shadow border border-secondary">
        <div>
            <h2 class="fw-bold text-white mb-0">Reservas</h2>
            <p class="text-info small mb-0">Control global del sistema</p>
        </div>

        <a href="/admin/adminPrinc" class="btn btn-outline-light">
            ← Volver
        </a>
    </div>

    <div class="card bg-dark bg-opacity-75 text-white shadow-lg border border-secondary">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">

                    <thead class="table-secondary text-dark text-uppercase small fw-bold">
                        <tr>
                            <th class="ps-4">Cliente</th>
                            <th>Cancha</th>
                            <th>Horario</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th class="pe-4">Acción</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if (reservas && reservas.length > 0) { %>

                            <% reservas.forEach(reserva => { %>
                                <tr>

                                    <td class="ps-4">
                                        <div class="fw-bold">
                                            <%= reserva.propietario ? reserva.propietario.nombre : 'Usuario' %>
                                        </div>
                                        <small class="text-muted">
                                            <%= reserva.propietario ? reserva.propietario.email : '' %>
                                        </small>
                                    </td>

                                    <td>
                                        <div class="fw-semibold text-info">
                                            <%= reserva.detalleHorario.datosCancha.nombre %>
                                        </div>
                                        <small class="text-muted">
                                            <%= reserva.detalleHorario.datosCancha.detalleTipo ? reserva.detalleHorario.datosCancha.detalleTipo.nombre : '' %>
                                        </small>
                                    </td>

                                    <td>
                                        <div class="small">
                                            <%= reserva.detalleHorario.fecha %>
                                        </div>
                                        <span class="badge border border-info text-info mt-1">
                                            <%= reserva.detalleHorario.hora_inicio.slice(0,5) %> - 
                                            <%= reserva.detalleHorario.hora_fin.slice(0,5) %>
                                        </span>
                                    </td>

                                    <td class="text-success fw-bold">
                                        Bs <%= reserva.total_pago || '0.00' %>
                                    </td>

                                    <td>
                                        <% if (reserva.estado === 'pagada') { %>
                                            <span class="badge bg-success">PAGADA</span>
                                        <% } else if (reserva.estado === 'confirmada') { %>
                                            <span class="badge bg-warning text-dark">CONFIRMADA</span>
                                        <% } else if (reserva.estado === 'cancelada') { %>
                                            <span class="badge bg-danger">CANCELADA</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary"><%= reserva.estado %></span>
                                        <% } %>
                                    </td>

                                    <td class="pe-4">
                                        <form action="/admin/reservas/actualizar/<%= reserva.id %>" method="POST">
                                            <select name="estado" onchange="this.form.submit()" class="form-select form-select-sm bg-dark text-white border-secondary">
                                                <option value="confirmada" <%= reserva.estado === 'confirmada' ? 'selected' : '' %>>Confirmar</option>
                                                <option value="pagada" <%= reserva.estado === 'pagada' ? 'selected' : '' %>>Pagada</option>
                                                <option value="cancelada" <%= reserva.estado === 'cancelada' ? 'selected' : '' %>>Cancelar</option>
                                            </select>
                                        </form>
                                    </td>

                                </tr>
                            <% }) %>

                        <% } else { %>

                            <tr>
                                <td colspan="6" class="text-center py-5 text-white">
                                    No hay reservas registradas
                                </td>
                            </tr>

                        <% } %>

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

</body>
</html>