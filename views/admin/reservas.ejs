<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Gestión de Reservas Global</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .table-container {
            background: rgba(33, 37, 41, 0.9);
            border-radius: 15px;
            overflow: hidden;
        }
        .badge-status {
            font-size: 0.75rem;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

<div class="container py-5">
    <div class="card table-container text-white shadow-lg border-0">
        <div class="card-header border-secondary text-center py-4">
            <h2 class="mb-0 fw-bold"><i class="fas fa-clipboard-list me-2 text-primary"></i>Control de Reservas Global</h2>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="table-secondary text-dark text-uppercase small fw-bold">
                        <tr>
                            <th class="ps-4">Cliente</th>
                            <th>Cancha / Deporte</th>
                            <th>Fecha y Horario</th>
                            <th>Monto Total</th>
                            <th>Estado Actual</th>
                            <th class="pe-4">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof reservas !== 'undefined' && reservas.length > 0) { %>
                            <% reservas.forEach(reserva => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold"><%= reserva.propietario ? reserva.propietario.nombre : 'Usuario N/A' %></div>
                                        <small class="text-muted"><%= reserva.propietario ? reserva.propietario.email : '' %></small>
                                    </td>
                                    
                                    <td>
                                        <span class="fw-semibold text-info"><%= reserva.detalleHorario.datosCancha.nombre %></span>
                                        <br>
                                        <span class="badge bg-light text-dark badge-status mt-1">
                                            <%= (reserva.detalleHorario.datosCancha.detalleTipo) ? reserva.detalleHorario.datosCancha.detalleTipo.descripcion : 'Deporte' %>
                                        </span>
                                    </td>
                                    
                                    <td>
                                        <div class="small"><i class="far fa-calendar-alt me-1"></i><%= reserva.detalleHorario.fecha %></div>
                                        <div class="badge bg-outline-info border border-info text-info mt-1">
                                            <i class="far fa-clock me-1"></i>
                                            <%= reserva.detalleHorario.horaInicio.slice(0, 5) %> - <%= reserva.detalleHorario.horaFin.slice(0, 5) %>
                                        </div>
                                    </td>
                                    
                                    <td class="text-success fw-bold">
                                        Bs. <%= reserva.totalPago || reserva.total_pago || '0.00' %>
                                    </td>
                                    
                                    <td>
                                        <% if (reserva.estado === 'pagada') { %>
                                            <span class="badge rounded-pill bg-success px-3 badge-status">PAGADA</span>
                                        <% } else if (reserva.estado === 'confirmada') { %>
                                            <span class="badge rounded-pill bg-warning text-dark px-3 badge-status">CONFIRMADA</span>
                                        <% } else if (reserva.estado === 'cancelada') { %>
                                            <span class="badge rounded-pill bg-danger px-3 badge-status">CANCELADA</span>
                                        <% } else { %>
                                            <span class="badge rounded-pill bg-secondary px-3 badge-status"><%= reserva.estado.toUpperCase() %></span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="pe-4">
                                        <form action="/admin/reservas/actualizar/<%= reserva.id %>" method="POST">
                                            <select name="estado" onchange="this.form.submit()" class="form-select form-select-sm bg-dark text-white border-secondary">
                                                <option value="confirmada" <%= reserva.estado === 'confirmada' ? 'selected' : '' %>>Confirmar</option>
                                                <option value="pagada" <%= reserva.estado === 'pagada' ? 'selected' : '' %>>Marcar Pagada</option>
                                                <option value="cancelada" <%= reserva.estado === 'cancelada' ? 'selected' : '' %>>Cancelar</option>
                                            </select>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No hay reservas registradas en el sistema actualmente.</h5>
                                    <a href="/admin/adminPrinc" class="btn btn-primary btn-sm mt-2">Volver al Panel</a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="card-footer text-end border-secondary bg-transparent py-3">
            <a href="/admin/adminPrinc" class="btn btn-outline-light btn-sm px-4">
                <i class="fas fa-chevron-left me-2"></i>Regresar al Inicio
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>