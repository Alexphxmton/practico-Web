<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Cancha - <%= cancha.nombre %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-dark text-light" 
      style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">


    <div class="d-flex justify-content-between align-items-center mb-4 bg-dark bg-opacity-75 p-3 rounded shadow border border-secondary">
        <div>
            <h4 class="mb-0">
                <i class="fas fa-edit me-2 text-warning"></i>
                Editar Cancha
            </h4>
            <small class="text-info"><%= cancha.nombre %></small>
        </div>

        <a href="/admin/canchas" class="btn btn-outline-light">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card bg-dark bg-opacity-75 border-secondary shadow-lg">

                <div class="card-body p-4">

                    <form action="/admin/canchas/editar/<%= cancha.id %>" method="POST">

                      
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" 
                                   name="nombre" 
                                   class="form-control bg-dark text-white border-secondary" 
                                   value="<%= cancha.nombre %>" 
                                   required>
                        </div>

                     
                        <div class="mb-3">
                            <label class="form-label">Tipo</label>
                            <select name="tipo_id" class="form-select bg-dark text-white border-secondary">

                                <% tipos.forEach(tipo => { %>
                                    <option value="<%= tipo.id %>" 
                                        <%= cancha.tipo_id == tipo.id ? 'selected' : '' %>>
                                        <%= tipo.nombre %>
                                    </option>
                                <% }) %>

                            </select>
                        </div>

                 
                        <div class="mb-3">
                            <label class="form-label">Precio por hora</label>
                            <input type="number" 
                                   name="precio_por_hora" 
                                   class="form-control bg-dark text-white border-secondary" 
                                   value="<%= cancha.precio_por_hora %>" 
                                   required>
                        </div>

                        
                        <div class="mb-4">
                            <label class="form-label">Estado</label>
                            <select name="estado" class="form-select bg-dark text-white border-secondary">
                                <option value="activa" <%= cancha.estado === 'activa' ? 'selected' : '' %>>
                                    Activa
                                </option>
                                <option value="inactiva" <%= cancha.estado === 'inactiva' ? 'selected' : '' %>>
                                    Inactiva
                                </option>
                            </select>
                        </div>

                    
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold">
                                <i class="fas fa-save me-1"></i> Guardar Cambios
                            </button>

                            <a href="/admin/canchas" class="btn btn-outline-light">
                                Cancelar
                            </a>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

</body>
</html>