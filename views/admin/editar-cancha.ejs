<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Cancha - <%= cancha.nombre %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background-color: #0b0f19; 
            color: #e9ecef;
            background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg');
            background-size: cover;
        }
        .form-card {
            background: rgba(26, 32, 44, 0.9);
            border: 1px solid #2d3748;
            border-radius: 15px;
            padding: 30px;
            margin-top: 50px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 form-card shadow-lg">
            <h2 class="text-center mb-4 text-info">Editar Cancha</h2>
            <hr class="border-secondary">
            
            <form action="/admin/canchas/editar/<%= cancha.id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label">Nombre de la Cancha</label>
                    <input type="text" name="nombre" class="form-control bg-dark text-white border-secondary" value="<%= cancha.nombre %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tipo de Deporte</label>
                    <select name="tipo_id" class="form-select bg-dark text-white border-secondary">
                        <% tipos.forEach(tipo => { %>
                            <option value="<%= tipo.id %>" <%= cancha.tipoId == tipo.id ? 'selected' : '' %>>
                                <%= tipo.descripcion %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Precio por Hora (Bs)</label>
                    <input type="number" name="precio_por_hora" class="form-control bg-dark text-white border-secondary" value="<%= cancha.precioHora %>" step="0.01" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Estado de la Cancha</label>
                    <select name="estado" class="form-select bg-dark text-white border-secondary">
                        <option value="activa" <%= cancha.estado === 'activa' ? 'selected' : '' %>>Activa (Visible al cliente)</option>
                        <option value="mantenimiento" <%= cancha.estado === 'mantenimiento' ? 'selected' : '' %>>En Mantenimiento (Oculta)</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                    <a href="/admin/canchas" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>