<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Registrar Cancha</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover;">

<div class="container py-5 text-white">
    <div class="row justify-content-center">
        <div class="col-md-6 p-4 rounded shadow" style="background-color: rgba(133, 161, 181, 0.9);">
            <h2 class="text-center mb-4 text-dark">Registrar Nueva Cancha</h2>
            
            <form action="/admin/canchas/guardar" method="POST">
                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Nombre de la Cancha</label>
                    <input type="text" name="nombre" class="form-control" placeholder="Ej: Cancha Central de Tenis" required>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Tipo de Deporte</label>
                    <select name="tipo_id" class="form-select" required>
                        <option value="">-- Seleccione el Deporte --</option>
                        <% tipos.forEach(tipo => { %>
                            <option value="<%= tipo.id %>"><%= tipo.descripcion %></option>
                        <% }) %>
                    </select>
                    <small class="text-muted">Si no aparece el deporte, créalo primero en "Tipos de Cancha".</small>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Precio por Hora (Bs)</label>
                    <input type="number" name="precio_por_hora" class="form-control" step="0.01" placeholder="0.00" required>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Estado Inicial</label>
                    <select name="estado" class="form-select">
                        <option value="activa">Activa (Visible para clientes)</option>
                        <option value="mantenimiento">En Mantenimiento</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success fw-bold">Guardar Cancha</button>
                    <a href="/admin/canchas" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>