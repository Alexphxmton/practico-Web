<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Registrar Cancha</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark" 
      style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5 bg-dark bg-opacity-50 p-4 rounded-3 shadow border border-secondary">
        <div>
            <h2 class="fw-bold text-white mb-0">➕ Nueva Cancha</h2>
            <p class="text-info small mb-0">Registrar un nuevo campo deportivo</p>
        </div>

        <a href="/admin/canchas" class="btn btn-outline-light">
            ← Volver
        </a>
    </div>

    <!-- FORM -->
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border border-secondary bg-dark bg-opacity-75 text-white">

                <div class="card-body p-4">

                    <form action="/admin/canchas/guardar" method="POST">

                       
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nombre</label>
                            <input type="text" name="nombre" class="form-control bg-dark text-white border-secondary" required>
                        </div>

                      
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tipo de Deporte</label>
                            <select name="tipo_id" class="form-select bg-dark text-white border-secondary" required>
                                <option value="">Seleccionar</option>
                                <% tipos.forEach(tipo => { %>
                                    <option value="<%= tipo.id %>"><%= tipo.nombre %></option>
                                <% }) %>
                            </select>
                        </div>

                       
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Precio por Hora (Bs)</label>
                            <input type="number" name="precio_por_hora" step="0.01" class="form-control bg-dark text-white border-secondary" required>
                        </div>

                      
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Estado</label>
                            <select name="estado" class="form-select bg-dark text-white border-secondary">
                                <option value="activa">Activa</option>
                                <option value="inactiva">Inactiva</option>
                            </select>
                        </div>

                       
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success fw-bold">
                                Guardar Cancha
                            </button>

                            <a href="/admin/canchas" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

</body>
</html>