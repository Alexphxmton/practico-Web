<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Canchas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background-image: url(https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg);">

<div class="container py-5">

    <h2 class="mb-4 text-center" style="color: white;">Canchas</h2>
    
    <!-- BOTÓN -->
    <div class="d-flex justify-content-end mb-4">
        <a href="/admin/canchas/nueva" class="btn btn-primary">
            Nueva Cancha
        </a>
    </div>
    

    <div class="row g-3">

        <% if (typeof canchas !== 'undefined' && canchas.length > 0) { %>

            <% canchas.forEach(cancha => { %>

                <div class="col-md-4" >
                    <div class="card shadow-sm" style="background-color: #85a1b5;">

                        <div class="card-body d-flex justify-content-between align-items-center">

                            <!-- INFO -->
                            <div>
                                <h5 class="mb-1"><%= cancha.nombre %></h5>
                                <small class="text-muted">
                                    Precio: Bs <%= cancha.precio_por_hora %>
                                </small>
                            </div>

                            
                            <div>
                                <a href="/admin/canchas/editar/<%= cancha.id %>" class="btn btn-warning btn-sm">
                                    Editar
                                </a>

                                <a href="/admin/canchas/eliminar/<%= cancha.id %>" class="btn btn-danger btn-sm">
                                    Eliminar
                                </a>
                            </div>

                        </div>

                    </div>
                </div>

            <% }) %>

        <% } else { %>

            <!-- MENSAJE CUANDO NO HAY DATOS -->
            <div class="col-12 text-center">
                <div class="alert alert-secondary">
                    No hay canchas registradas
                </div>
            </div>

        <% } %>

    </div>

</div>

</body>
</html>