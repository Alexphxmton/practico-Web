<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Gestión de Canchas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .card-cancha {
            transition: transform 0.3s, box-shadow 0.3s;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 15px;
        }
        .card-cancha:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4) !important;
        }
        .badge-price {
            font-size: 1.1rem;
            color: #2ecc71;
        }
        body {
            background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5 bg-dark bg-opacity-50 p-4 rounded-3 shadow-sm border border-secondary">
        <div>
            <h2 class="fw-bold text-white mb-0">🏟️ Panel de Canchas</h2>
            <p class="text-info mb-0 small">Administración y control de inventario</p>
        </div>
        <div>
            <a href="/admin/adminPrinc" class="btn btn-outline-light me-2">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </a>
            <a href="/admin/canchas/nueva" class="btn btn-primary shadow fw-bold">
                <i class="fas fa-plus me-1"></i> Nueva Cancha
            </a>
        </div>
    </div>

    <div class="row g-4">
        <% if (typeof canchas !== 'undefined' && canchas.length > 0) { %>
            <% canchas.forEach(cancha => { %>
                <div class="col-md-4">
                    <div class="card card-cancha shadow-lg" style="background-color: #85a1b5;">
                        <div class="card-body p-4 text-dark">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h4 class="card-title fw-bold mb-0"><%= cancha.nombre %></h4>
                                <span class="badge <%= cancha.estado === 'activa' ? 'bg-success' : 'bg-danger' %> shadow-sm">
                                    <i class="fas <%= cancha.estado === 'activa' ? 'fa-check-circle' : 'fa-tools' %> me-1"></i>
                                    <%= cancha.estado.toUpperCase() %>
                                </span>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <span class="badge bg-dark me-2">Deporte:</span>
                                    <span class="fw-semibold">
                                        <%= cancha.detalleTipo ? cancha.detalleTipo.descripcion : 'No asignado' %>
                                    </span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-dark me-2">Precio:</span>
                                    <span class="fw-bold badge-price">Bs <%= cancha.precioHora %></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 border-top border-dark border-opacity-25 pt-3">
                                <a href="/admin/canchas/editar/<%= cancha.id %>" class="btn btn-warning btn-sm px-3 shadow-sm fw-bold">
                                    <i class="fas fa-edit me-1"></i> Editar
                                </a>

                                <form action="/admin/canchas/eliminar/<%= cancha.id %>" method="POST" 
                                      onsubmit="return confirm('¿Estás totalmente seguro de eliminar la cancha: <%= cancha.nombre %>? Esta acción no se puede deshacer.')">
                                    <button type="submit" class="btn btn-danger btn-sm px-3 shadow-sm fw-bold">
                                        <i class="fas fa-trash-alt me-1"></i> Eliminar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center">
                <div class="alert alert-dark bg-opacity-75 text-white border-secondary py-5 shadow">
                    <i class="fas fa-futbol fa-3x mb-3 text-muted"></i>
                    <h4>No hay canchas registradas</h4>
                    <p class="mb-3">Aún no has añadido campos de juego a tu base de datos.</p>
                    <a href="/admin/canchas/nueva" class="btn btn-primary">Crear mi primera cancha</a>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>