<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Gestión de Horarios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg'); background-size: cover; background-attachment: fixed;">

<div class="container py-5">
    <div class="text-center text-white mb-5">
        <h1 class="display-5 fw-bold">Gestión de Horarios Disponibles</h1>
        <p class="lead">Configura los bloques de tiempo para cada cancha</p>
    </div>

    <div class="card bg-dark bg-opacity-75 text-white shadow-lg mb-5">
        <div class="card-header border-secondary">
            <h5 class="mb-0">Añadir Nuevo Horario</h5>
        </div>
        <div class="card-body">
            <form action="/admin/horarios/agregar" method="POST" class="row g-3 p-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Seleccionar Cancha</label>
                    <select name="cancha_id" class="form-select bg-dark text-white border-secondary" required>
                        <% canchas.forEach(cancha => { %>
                            <option value="<%= cancha.id %>"><%= cancha.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Fecha</label>
                    <input type="date" name="fecha" class="form-control bg-dark text-white border-secondary" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Inicio</label>
                    <input type="time" name="hora_inicio" class="form-control bg-dark text-white border-secondary" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Fin</label>
                    <input type="time" name="hora_fin" class="form-control bg-dark text-white border-secondary" required>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary fw-bold">Añadir</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card bg-dark bg-opacity-75 text-white shadow-lg">
        <div class="card-header border-secondary d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Horarios Generados</h5>
            <a href="/admin/adminPrinc" class="btn btn-outline-light btn-sm">Volver al Panel</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead class="table-secondary text-dark">
                        <tr>
                            <th>Cancha</th>
                            <th>Fecha</th>
                            <th>Horario</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof horarios !== 'undefined' && horarios.length > 0) { %>
                            <% horarios.forEach(horario => { %>
                                <tr>
                                    <td><strong class="text-info"><%= horario.datosCancha.nombre %></strong></td>
                                    <td><%= horario.fecha %></td>
                                    <td>
                                        <span class="badge bg-secondary">
                                        <%= horario.horaInicio.slice(0, 5) %> - <%= horario.horaFin.slice(0, 5) %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (horario.disponible) { %>
                                            <span class="badge bg-success">Libre</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Ocupado</span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <form action="/admin/horarios/eliminar/<%= horario.id %>" method="POST" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar este horario?')">
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No hay horarios creados para estas canchas.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

</body>
</html>