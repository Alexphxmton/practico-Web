<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel Administrativo - Golazo App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-image: url('https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg');
            background-size: cover;
            background-attachment: fixed;
        }
        .card-admin {
            background-color: #85a1b5;
            transition: transform 0.2s;
            border: none;
        }
        .card-admin:hover {
            transform: scale(1.05);
            background-color: #a3bac9;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-dark bg-dark bg-opacity-75 mb-5 shadow">
    <div class="container">
        <span class="navbar-brand mb-0 h1"><i class="fas fa-user-shield me-2"></i>Admin Dashboard</span>
        <a href="/logout" class="btn btn-outline-danger">
            <i class="fas fa-sign-out-alt me-1"></i> Cerrar Sesión
        </a>
    </div>
</nav>

<div class="container mt-4">
    <h2 class="text-center mb-5 fw-bold" style="color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
        GESTIÓN DEL SISTEMA
    </h2>

    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <a href="/admin/canchas" class="text-decoration-none text-dark">
                <div class="card card-admin shadow text-center p-4">
                    <i class="fas fa-stadium fa-3x mb-3"></i>
                    <h4>Canchas</h4>
                    <p class="small">Gestionar inventario</p>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/admin/tipoCancha" class="text-decoration-none text-dark">
                <div class="card card-admin shadow text-center p-4">
                    <i class="fas fa-futbol fa-3x mb-3"></i>
                    <h4>Deportes</h4>
                    <p class="small">Categorías de juego</p>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/admin/horarios" class="text-decoration-none text-dark">
                <div class="card card-admin shadow text-center p-4">
                    <i class="fas fa-clock fa-3x mb-3"></i>
                    <h4>Horarios</h4>
                    <p class="small">Disponibilidad</p>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/admin/reservas" class="text-decoration-none text-dark">
                <div class="card card-admin shadow text-center p-4">
                    <i class="fas fa-calendar-check fa-3x mb-3"></i>
                    <h4>Reservas</h4>
                    <p class="small">Control global</p>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a href="/admin/resenas" class="text-decoration-none text-dark">
                <div class="card card-admin shadow text-center p-4">
                    <i class="fas fa-star fa-3x mb-3"></i>
                    <h4>Reseñas</h4>
                    <p class="small">Moderación</p>
                </div>
            </a>
        </div>
    </div>
</div>

</body>
</html>