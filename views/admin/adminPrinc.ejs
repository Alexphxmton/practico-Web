<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background-image:url(https://www.roc21.com/wp-content/uploads/2012/09/fondos-para-pa%CC%81ginas-web-6.jpg);   ">

<div class="container mt-5">

    <h2 class="text-center mb-4" style="color: white;">Panel Administrativo</h2>

    <div class="row">

      
        <div class="col-md-3">
            <a href="/admin/canchas" class="text-decoration-none text-dark">
                <div class="card shadow text-center p-4 mb-4" style="background-color: #85a1b5;">
                    <h4> Canchas</h4>
                    <p>Ver y gestionar canchas</p>
                </div>
            </a>
        </div>


        <div class="col-md-3">
            <a href="/admin/tipoCancha" class="text-decoration-none text-dark">
